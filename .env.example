# Root environment template for local dev and deployment wiring
# Copy to .env.local for your machine-specific values.

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8787

# Backend (Cloudflare Worker runtime vars)
JWT_SECRET=replace-with-a-strong-secret
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# Cloudflare deployment (GitHub Actions/CLI)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Vercel deployment (GitHub Actions)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id
