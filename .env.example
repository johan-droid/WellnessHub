# Root environment template for development and deployment
# Copy to .env.local for your machine-specific values

# ============ FRONTEND ============
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_ENVIRONMENT=development
NODE_ENV=development

# ============ BACKEND (Wrangler) ============
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENVIRONMENT=development
LOG_LEVEL=debug

# ============ DATABASE (Optional - PostgreSQL) ============
POSTGRES_USER=wellness
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=wellbeing_db

# ============ REDIS (Optional) ============
REDIS_PASSWORD=

# ============ PGADMIN (Optional) ============
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ============ CLOUDFLARE DEPLOYMENT ============
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_SUBDOMAIN=your-workers-subdomain

# ============ VERCEL DEPLOYMENT ============
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_APP_DOMAIN=your-vercel-domain.vercel.app

# ============ GITHUB ACTIONS SECRETS ============
# These should be set as GitHub repository secrets, not in .env
# CLOUDFLARE_API_TOKEN=***
# CLOUDFLARE_ACCOUNT_ID=***
# VERCEL_TOKEN=***
# VERCEL_ORG_ID=***
# VERCEL_PROJECT_ID=***
# SLACK_WEBHOOK_URL=*** (optional, for deployment notifications)
