# Backend local worker variables for Wrangler/Cloudflare Workers
# Copy this file to .dev.vars and replace with your own values
#
# Required by current backend code:
# - JWT_SECRET
# Optional in code (defaults applied when omitted):
# - CORS_ORIGINS
# - ENVIRONMENT

# ============ REQUIRED ============
# Generate using: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters

# ============ OPTIONAL ============
# Comma-separated list for local frontend origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
ENVIRONMENT=development

# ============ NOTES ============
# Cloudflare D1 binding is configured in wrangler.jsonc as binding "DB".
# Do not set DB here.
#
# Legacy/unused vars were intentionally removed from this template.
