# Frontend Next.js Environment Variables
# Copy this file to .env.local and update with your values

# ============ API CONFIGURATION ============
# Backend API URL - change for production
NEXT_PUBLIC_API_URL=http://localhost:8787
# Production example: NEXT_PUBLIC_API_URL=https://wellnesshub01.<your-subdomain>.workers.dev
NEXT_PUBLIC_API_TIMEOUT=30000

# ============ AUTHENTICATION ============
# Token storage and security
NEXT_PUBLIC_TOKEN_STORAGE_KEY=auth_token
NEXT_PUBLIC_TOKEN_EXPIRY_KEY=auth_token_expires

# ============ ENVIRONMENT ============
NEXT_PUBLIC_ENVIRONMENT=development
NODE_ENV=development

# ============ ANALYTICS (Optional) ============
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# ============ FEATURE FLAGS ============
NEXT_PUBLIC_ENABLE_2FA=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_TRACKING=false

# ============ APP METADATA ============
NEXT_PUBLIC_APP_NAME=Wellness Travel Hub
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0
